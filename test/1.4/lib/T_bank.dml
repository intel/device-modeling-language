dml 1.4;

device test;

/// DMLC-FLAG --breaking-change=shared-logs-locally

attribute trigger_test is write_only_attr {
    param type = "n";
    method set(attr_value_t a) throws {
        b.set(0, 0, 0xDEADBEEF);
        b.set(0x100, 9, 0xDEADBEEF);
        try {
            _ = b.get(0, 0);
            assert false;
        } catch;
        try {
            _ = b.get(0x100, 9);
            assert false;
        } catch;
    }
}

bank b;
