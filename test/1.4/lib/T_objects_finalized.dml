dml 1.4;

device test;

/// INSTANTIATE-MANUALLY

saved bool objects_finalized_done;

connect partner;

method objects_finalized() {
    assert SIM_object_is_configured(dev.obj);
    assert SIM_object_is_configured(partner.obj);
    objects_finalized_done = true;
}

// objects_finalized template ensures objects_finalized() of children are
// called first.
// This applies to DML objects in general. Port classes for
// banks/ports/subdevices don't each register their own objects_finalized
// method, it all relies on the objects_finalized registered for the device
// class.
template sub_objects_finalized is objects_finalized {
    saved bool objects_finalized_done;
    shared method objects_finalized() {
        assert !dev.objects_finalized_done;
        objects_finalized_done = true;
    }
}

group g is sub_objects_finalized;
subdevice s is sub_objects_finalized;
